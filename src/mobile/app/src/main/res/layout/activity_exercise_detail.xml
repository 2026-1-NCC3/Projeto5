<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- IMAGEM DO EXERCÍCIO (topo, ocupa largura total) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:background="#DCF0FA">

                <ImageView
                    android:id="@+id/ivExerciseImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_exercise_placeholder"
                    android:contentDescription="Imagem do exercício" />

                <!-- Botão voltar sobre a imagem -->
                <ImageView
                    android:id="@+id/ivBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="16dp"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:src="@drawable/ic_arrow_back"
                    android:background="@drawable/bg_circle_white_alpha"
                    android:padding="8dp"
                    android:contentDescription="Voltar" />

            </RelativeLayout>

            <!-- CONTEÚDO ABAIXO DA IMAGEM -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="453dp"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Título -->
                <TextView
                    android:id="@+id/tvExerciseTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Nome do Exercício"
                    android:textColor="#222222"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <!-- Chip de frequência -->
                <TextView
                    android:id="@+id/tvFrequency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/bg_semanal_pill"
                    android:paddingStart="14dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="6dp"
                    android:text="3x por semana"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />

                <!-- Divisória -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="16dp"
                    android:background="#EEEEEE" />

                <!-- Seção: Orientações -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Orientações"
                    android:textColor="#222222"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:lineSpacingMultiplier="1.5"
                    android:text="Descrição do exercício aparecerá aqui."
                    android:textColor="#555555"
                    android:textSize="14sp" />

                <!-- Seção: Como executar -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Como executar"
                    android:textColor="#222222"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Passo 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/circle_purple"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Posicione-se conforme indicado pela fisioterapeuta."
                        android:textColor="#555555"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Passo 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/circle_purple"
                        android:gravity="center"
                        android:text="2"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Execute o movimento de forma lenta e controlada."
                        android:textColor="#555555"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Passo 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/circle_purple"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Respire normalmente durante toda a execução."
                        android:textColor="#555555"
                        android:textSize="14sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnConcluir"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="#2E4A6E"
                    android:text="Marcar como concluído"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    app:cornerRadius="16dp" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>