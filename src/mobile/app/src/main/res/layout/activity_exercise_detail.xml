<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="320dp"
                app:cardElevation="0dp"
                app:cardCornerRadius="0dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerBottom">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/ivExerciseImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_exercise_placeholder" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:background="@drawable/gradient_top_shadow" />

                    <ImageButton
                        android:id="@+id/ivBack"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_margin="16dp"
                        android:background="@drawable/bg_circle_white"
                        android:elevation="4dp"
                        android:src="@drawable/ic_arrow_back"
                        app:tint="#2E4A6E" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvExerciseTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nome do Exercício"
                    android:textColor="#1A1A1A"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:id="@+id/tvFrequency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/bg_pill_blue_light"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="3x por semana"
                    android:textColor="#2E4A6E"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <include
                        android:id="@+id/step1"
                        layout="@layout/item_step" />

                    <include
                        android:id="@+id/step2"
                        layout="@layout/item_step" />

                    <include
                        android:id="@+id/step3"
                        layout="@layout/item_step" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Orientações da Dra. Maya"
                    android:textColor="#2E4A6E"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="32dp"
                    android:lineSpacingExtra="6sp"
                    android:text="Descrição detalhada aqui..."
                    android:textColor="#666666"
                    android:textSize="15sp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#F8FAFC"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp">

                </com.google.android.material.card.MaterialCardView>

                <Button
                    android:id="@+id/btnConcluir"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="40dp"
                    android:backgroundTint="#2E4A6E"
                    android:text="Concluir Exercício"
                    android:textAllCaps="false"
                    android:textSize="18sp"
                    app:cornerRadius="18dp"
                    app:icon="@drawable/ic_check"
                    app:iconGravity="textStart" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>