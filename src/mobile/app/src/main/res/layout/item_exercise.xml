<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp">

        <!-- Thumbnail -->
        <ImageView
            android:id="@+id/ivExerciseThumb"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_exercise_thumb"
            android:src="@drawable/ic_exercise_placeholder"
            android:contentDescription="Imagem do exercício" />

        <!-- Título + Frequência -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/ivExerciseThumb"
            android:layout_toStartOf="@+id/ivPlayBtn"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvExerciseTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Exercício"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#222222" />

            <TextView
                android:id="@+id/tvExerciseFrequency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3x por semana"
                android:textSize="12sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Botão play -->
        <ImageView
            android:id="@+id/ivPlayBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_play_button"
            android:src="@drawable/ic_play_arrow"
            android:padding="10dp"
            android:contentDescription="Ver exercício" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>