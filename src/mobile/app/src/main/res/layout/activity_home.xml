<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- parte principal -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_home_gradient">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="72dp"
            android:clipToPadding="false"
            android:scrollbars="none"
            android:background="@android:color/transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- HEADER -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp">

                    <ImageView
                        android:id="@+id/ivMenu"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_centerVertical="true"
                        android:layout_alignParentStart="true"
                        android:src="@drawable/ic_menu"
                        android:contentDescription="Menu" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/ivNotification"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/ic_notifications"
                            android:contentDescription="Notificações" />

                        <ImageView
                            android:id="@+id/ivProfile"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_marginStart="14dp"
                            android:src="@drawable/ic_person"
                            android:contentDescription="Perfil" />

                    </LinearLayout>
                </RelativeLayout>

                <!-- SAUDAÇÃO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Seja bem-vindo(a),"
                        android:textSize="20sp"
                        android:textColor="#222222" />

                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Usuário"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#222222" />

                    <TextView
                        android:id="@+id/tvSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Realize seu check-in e verifique seu plano de exercícios"
                        android:textSize="13sp"
                        android:textColor="#555555"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- TÍTULO SEÇÃO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Plano de Exercícios"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#222222"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp" />

                <!-- CARD PLANO DE EXERCÍCIOS -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardExercisePlan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#2E4A6E">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_centerVertical="true">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dia 4"
                                android:textSize="30sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Reorganizar a postura"
                                android:textSize="14sp"
                                android:textColor="#AACCEE" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/ivExerciseArrow"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_forward"
                            android:background="@drawable/bg_circle_white_alpha"
                            android:padding="10dp"
                            android:contentDescription="Ver exercícios" />

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- BOTTOM NAV -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="#FFFFFF"
            app:menu="@menu/bottom_nav_menu"
            app:itemIconTint="@color/bottom_nav_selector"
            app:itemTextColor="@color/bottom_nav_selector"
            app:labelVisibilityMode="labeled"
            app:itemActiveIndicatorStyle="@android:style/Widget" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- ==========================================
         MENU LATERAL (DRAWER)
         gravity="start" = desliza da esquerda
         ========================================== -->
    <LinearLayout
        android:id="@+id/drawerMenu"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:paddingTop="48dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:elevation="8dp">

        <!-- Ícone do hambúrguer no topo do drawer -->
        <ImageView
            android:id="@+id/ivDrawerClose"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_menu"
            android:layout_marginBottom="32dp"
            android:contentDescription="Fechar menu" />

        <!-- Divisória -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="24dp" />

        <!-- HOME -->
        <LinearLayout
            android:id="@+id/menuHome"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_home"
                android:contentDescription="Home" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="16sp"
                android:textColor="#222222"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- MESSAGES -->
        <LinearLayout
            android:id="@+id/menuMessages"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_chat"
                android:contentDescription="Messages" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Messages"
                android:textSize="16sp"
                android:textColor="#222222"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- NOTIFICATIONS -->
        <LinearLayout
            android:id="@+id/menuNotifications"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_notifications"
                android:contentDescription="Notifications" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notifications"
                android:textSize="16sp"
                android:textColor="#222222"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- SETTINGS -->
        <LinearLayout
            android:id="@+id/menuSettings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_settings"
                android:contentDescription="Settings" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textSize="16sp"
                android:textColor="#222222"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- CHECK-IN -->
        <LinearLayout
            android:id="@+id/menuCheckin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_checkin"
                android:contentDescription="Check-In" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Check-In"
                android:textSize="16sp"
                android:textColor="#222222"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- EVOLUÇÃO -->
        <LinearLayout
            android:id="@+id/menuEvolucao"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_evolucao"
                android:contentDescription="Evolução" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Evolução"
                android:textSize="16sp"
                android:textColor="#222222"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- PLANO DE EXERCÍCIOS -->
        <LinearLayout
            android:id="@+id/menuPlano"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_plano"
                android:contentDescription="Plano de Exercícios" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Plano de Exercícios"
                android:textSize="16sp"
                android:textColor="#222222"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- AGENDA -->
        <LinearLayout
            android:id="@+id/menuAgenda"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_calendar"
                android:contentDescription="Agenda" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agenda"
                android:textSize="16sp"
                android:textColor="#222222"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- PERFIL -->
        <LinearLayout
            android:id="@+id/menuPerfil"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_person"
                android:contentDescription="Perfil" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perfil"
                android:textSize="16sp"
                android:textColor="#222222"
                android:layout_marginStart="16dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>